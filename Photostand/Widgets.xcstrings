            "state": "translated",
            "value": "포토 그리드"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "照片网格"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "照片網格"
          }
        }
      }
    },

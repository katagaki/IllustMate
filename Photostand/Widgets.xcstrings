    "PhotoGrid.Intent.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle ein Album aus, um zufällige Bilder im Raster anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose an album to display a grid of random pics from."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランダムな写真をグリッド表示するアルバムを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무작위 사진을 그리드로 표시할 앨범을 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个相册以网格显示随机图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇一個相簿以網格顯示隨機圖片。"
          }
        }
      }
    },

{
  "sourceLanguage": "en",
  "strings": {
    "PhotoGrid.Description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt ein Raster zufälliger Bilder aus einem ausgewählten Album an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display a grid of random pics from a selected album."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したアルバムからランダムな写真をグリッド表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 앨범에서 무작위 사진을 그리드로 표시합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从选定的相册中以网格显示随机图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從選定的相簿中以網格顯示隨機圖片。"
          }
        }
      }
    },
    "PhotoGrid.DisplayName": {
      "extractionState": "manual",

    "Import.Instructions": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select photos or an album to import from your Photos library, then select Start Import."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「写真」アプリからインポートしたい写真を選択する、またはアルバムから選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진 보관함에서 사진이나 앨범을 선택한 후 가져오기 시작을 누르세요."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從您的照片圖庫中選擇照片或相簿，然後點選「開始匯入」。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从您的照片图库中选择照片或相册，然后点击「开始导入」。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie Fotos oder ein Album aus Ihrer Fotomediathek aus und tippen Sie dann auf „Import starten“."
          }
        }
      }
    },
    "Import.OpenSettings": {
      "extractionState": "manual",

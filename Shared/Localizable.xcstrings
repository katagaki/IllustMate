    "More.Debug.Warning.Text" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle hier geГӨnderten Einstellungen sind experimentell und erfordern mГ¶glicherweise einen Neustart der App.\nDer Entwickler Гјbernimmt keine Verantwortung fГјr Datenverluste, die durch Г„nderungen der folgenden Optionen verursacht werden."

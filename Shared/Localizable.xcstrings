    "More.Troubleshooting.DataManagement.Description" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PicMate nutzt den Speicherplatz gelГ¶schter Bilder fГјr neue Daten.\nSie kГ¶nnen diesen Speicherplatz sofort freigeben, indem Sie auf вҖһSpeicherplatz freigebenвҖң tippen."

    "Alert.DeleteAll.Text": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete all your data? This operation cannot be undone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのデータを削除してもよろしいですか？\n削除後、データは復元できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 데이터를 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除所有資料嗎？此操作無法復原。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除所有数据吗？此操作无法撤销。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie wirklich alle Daten löschen? Dieser Vorgang kann nicht rückgängig gemacht werden."
          }
        }
      }
    },

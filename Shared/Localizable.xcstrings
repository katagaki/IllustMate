          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie „%@“ wirklich löschen?"
          }
        }
      }
    },
    "Shared.DeleteConfirmation.Album.Message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Items contained in the deleted album will be moved to its parent album."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除されたアルバム内のアイテムは親アルバムに移動されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제된 앨범에 포함된 항목은 상위 앨범으로 이동됩니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已刪除相簿中的項目將被移至其上層相簿。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已删除相册中的项目将被移至其上级相册。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Elemente im gelöschten Album werden in das übergeordnete Album verschoben."
          }
        }
      }
    },

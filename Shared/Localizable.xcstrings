      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MГ¶chten Sie dieses Album wirklich lГ¶schen?\nBilder im Album werden in das Гјbergeordnete Album verschoben."

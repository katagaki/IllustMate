    "More.Debug.Warning.Text": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Any setting changed here are experimental and may require a restart of the app to take effect.\nThe developer is not responsible for any data loss caused by any modification of the below options."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "こちらの設定は実験的なものであり、アプリを再起動する必要がある場合があります。\n本アプリの開発者は、こちらの設定によるデータ損失の責任を一切負いかねます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 변경한 설정은 실험적이며 앱을 재시작해야 적용될 수 있습니다.\n아래 옵션 변경으로 인한 데이터 손실에 대해 개발자는 책임지지 않습니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此處的設定為實驗性質，可能需要重新啟動 App 才能生效。\n開發者對因修改以下選項而造成的任何資料遺失概不負責。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此处的设置为实验性质，可能需要重新启动 App 才能生效。\n开发者对因修改以下选项而造成的任何数据丢失概不负责。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle hier geänderten Einstellungen sind experimentell und erfordern möglicherweise einen Neustart der App.\nDer Entwickler übernimmt keine Verantwortung für Datenverluste, die durch Änderungen der folgenden Optionen verursacht werden."
          }
        }
      }
    },

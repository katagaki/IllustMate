        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "еңЁгҖҢз…§зүҮгҖҚжЁЎејҸдёӢпјҢеҰӮжһңиіҮж–ҷеӨҫдёӯеҢ…еҗ«еҗҚзЁұеүҚжңүгҖҢв–¶пёҺ гҖҚзҡ„зӣёз°ҝдё”еҗҚзЁұиҲҮиіҮж–ҷеӨҫзӣёеҗҢпјҢи©Ізӣёз°ҝзҡ„з…§зүҮе°ҮжҲҗзӮәиіҮж–ҷеӨҫжң¬иә«зҡ„ең–зүҮгҖӮе…¶йӨҳзӣёз°ҝе°ҮжҲҗзӮәе·ўзӢҖеӯҗзӣёз°ҝгҖӮ"

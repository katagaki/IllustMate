        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "зЎ®е®ҡиҰҒеҲ йҷӨжӯӨзӣёеҶҢеҗ—пјҹ\nзӣёеҶҢдёӯзҡ„еӣҫзүҮе°Ҷиў«з§»иҮіе…¶дёҠзә§зӣёеҶҢгҖӮ"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "зўәе®ҡиҰҒеҲӘйҷӨжӯӨзӣёз°ҝе—Һпјҹ\nзӣёз°ҝдёӯзҡ„ең–зүҮе°Үиў«з§»иҮіе…¶дёҠеұӨзӣёз°ҝгҖӮ"

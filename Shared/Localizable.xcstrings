        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PicMate reuses existing space used by deleted pics to populate new data.\nYou can immediately free up this space by tapping вҖҳFree Up SpaceвҖҷ."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "гғ”гғғгӮҜгғЎгӮӨгғҲгҒҜгҖҒеүҠйҷӨгҒ•гӮҢгҒҹз”»еғҸгҒ®гғҮгӮЈгӮ№гӮҜй ҳеҹҹгӮ’еҶҚеҲ©з”ЁгҒ—гҖҒж–°гҒ—гҒ„з”»еғҸгӮ’дҝқеӯҳгҒ—гҒҫгҒҷгҖӮ\nгғҮгӮЈгӮ№гӮҜй ҳеҹҹгӮ’гҒҷгҒҗгҒ«еў—гӮ„гҒ—гҒҹгҒ„е ҙеҗҲгҖҒгҖҢз©әгҒҚй ҳеҹҹгӮ’еў—гӮ„гҒҷгҖҚгӮ’гӮҝгғғгғҒгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PicMateлҠ” мӮӯм ңлҗң мӮ¬м§„мқҙ мӮ¬мҡ©н•ҳлҚҳ кіөк°„мқ„ мһ¬мӮ¬мҡ©н•ҳм—¬ мғҲлЎңмҡҙ лҚ°мқҙн„°лҘј м ҖмһҘн•©лӢҲлӢӨ.\n'кіөк°„ нҷ•ліҙ'лҘј лҲҢлҹ¬ мқҙ кіөк°„мқ„ мҰүмӢң нҷ•ліҙн•  мҲҳ мһҲмҠөлӢҲлӢӨ."
          }

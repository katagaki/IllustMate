    "More.Troubleshooting.DataManagement.Description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PicMate reuses existing space used by deleted pics to populate new data.\nYou can immediately free up this space by tapping ‘Free Up Space’."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピックメイトは、削除された画像のディスク領域を再利用し、新しい画像を保存します。\nディスク領域をすぐに増やしたい場合、「空き領域を増やす」をタッチしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PicMate는 삭제된 사진이 사용하던 공간을 재사용하여 새로운 데이터를 저장합니다.\n'공간 확보'를 눌러 이 공간을 즉시 확보할 수 있습니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "PicMate 會重複使用已刪除圖片所佔用的空間來儲存新資料。\n您可以點選「釋放空間」來立即釋放這些空間。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PicMate 会重复使用已删除图片所占用的空间来存储新数据。\n您可以点击「释放空间」来立即释放这些空间。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PicMate nutzt den Speicherplatz gelöschter Bilder für neue Daten.\nSie können diesen Speicherplatz sofort freigeben, indem Sie auf „Speicherplatz freigeben“ tippen."
          }
        }
      }
    },

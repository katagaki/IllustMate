        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "гҒ“гҒ®гӮўгғ«гғҗгғ гӮ’еүҠйҷӨгҒ—гҒҰгӮӮгӮҲгӮҚгҒ—гҒ„гҒ§гҒҷгҒӢпјҹ\nгӮўгғ«гғҗгғ еҶ…гҒ®з”»еғҸгҒҜгҒқгҒ®гӮўгғ«гғҗгғ гҒ®еҢ…еҗ«гӮўгғ«гғҗгғ гҒ«жҲ»гҒ•гӮҢгҒҫгҒҷгҖӮ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "мқҙ м•ЁлІ”мқ„ мӮӯм ңн•ҳмӢңкІ мҠөлӢҲк№Ң?\nм•ЁлІ” лӮҙмқҳ мӮ¬м§„мқҖ мғҒмң„ м•ЁлІ”мңјлЎң мқҙлҸҷлҗ©лӢҲлӢӨ."

        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "жӯӨеӨ„зҡ„и®ҫзҪ®дёәе®һйӘҢжҖ§иҙЁпјҢеҸҜиғҪйңҖиҰҒйҮҚж–°еҗҜеҠЁ App жүҚиғҪз”ҹж•ҲгҖӮ\nејҖеҸ‘иҖ…еҜ№еӣ дҝ®ж”№д»ҘдёӢйҖүйЎ№иҖҢйҖ жҲҗзҡ„д»»дҪ•ж•°жҚ®дёўеӨұжҰӮдёҚиҙҹиҙЈгҖӮ"

        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PicMate дјҡйҮҚеӨҚдҪҝз”Ёе·ІеҲ йҷӨеӣҫзүҮжүҖеҚ з”Ёзҡ„з©әй—ҙжқҘеӯҳеӮЁж–°ж•°жҚ®гҖӮ\nжӮЁеҸҜд»ҘзӮ№еҮ»гҖҢйҮҠж”ҫз©әй—ҙгҖҚжқҘз«ӢеҚійҮҠж”ҫиҝҷдәӣз©әй—ҙгҖӮ"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PicMate жңғйҮҚиӨҮдҪҝз”Ёе·ІеҲӘйҷӨең–зүҮжүҖдҪ”з”Ёзҡ„з©әй–“дҫҶе„Іеӯҳж–°иіҮж–ҷгҖӮ\nжӮЁеҸҜд»Ҙй»һйҒёгҖҢйҮӢж”ҫз©әй–“гҖҚдҫҶз«ӢеҚійҮӢж”ҫйҖҷдәӣз©әй–“гҖӮ"

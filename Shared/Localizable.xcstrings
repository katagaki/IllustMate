        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "гҒ“гҒЎгӮүгҒ®иЁӯе®ҡгҒҜе®ҹйЁ“зҡ„гҒӘгӮӮгҒ®гҒ§гҒӮгӮҠгҖҒгӮўгғ—гғӘгӮ’еҶҚиө·еӢ•гҒҷгӮӢеҝ…иҰҒгҒҢгҒӮгӮӢе ҙеҗҲгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ\nжң¬гӮўгғ—гғӘгҒ®й–ӢзҷәиҖ…гҒҜгҖҒгҒ“гҒЎгӮүгҒ®иЁӯе®ҡгҒ«гӮҲгӮӢгғҮгғјгӮҝжҗҚеӨұгҒ®иІ¬д»»гӮ’дёҖеҲҮиІ гҒ„гҒӢгҒӯгҒҫгҒҷгҖӮ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "м—¬кё°м—җм„ң ліҖкІҪн•ң м„Өм •мқҖ мӢӨн—ҳм Ғмқҙл©° м•ұмқ„ мһ¬мӢңмһ‘н•ҙм•ј м Ғмҡ©лҗ  мҲҳ мһҲмҠөлӢҲлӢӨ.\nм•„лһҳ мҳөм…ҳ ліҖкІҪмңјлЎң мқён•ң лҚ°мқҙн„° мҶҗмӢӨм—җ лҢҖн•ҙ к°ңл°ңмһҗлҠ” мұ…мһ„м§Җм§Җ м•ҠмҠөлӢҲлӢӨ."

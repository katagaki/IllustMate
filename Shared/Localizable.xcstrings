    "More.Experiments.NestedAlbums.Description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Fotos-Modus: Wenn ein Ordner ein Album mit вҖһв–¶пёҺ вҖң vor dem Ordnernamen enthГӨlt, werden die Fotos dieses Albums zu den eigenen Bildern des Ordners. Die Гјbrigen Alben werden zu verschachtelten Unteralben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Photos mode, if a folder contains an album with 'в–¶пёҺ ' before the folder's name, that album's photos become the folder's own pics. Remaining albums become nested sub-albums."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "еҶҷзңҹгғўгғјгғүгҒ§гҖҒгғ•гӮ©гғ«гғҖеҶ…гҒ«гғ•гӮ©гғ«гғҖеҗҚгҒ®еүҚгҒ«гҖҢв–¶пёҺ гҖҚгҒҢд»ҳгҒ„гҒҹгӮўгғ«гғҗгғ гҒҢгҒӮгӮӢе ҙеҗҲгҖҒгҒқгҒ®гӮўгғ«гғҗгғ гҒ®еҶҷзңҹгҒҢгғ•гӮ©гғ«гғҖиҮӘдҪ“гҒ®еҶҷзңҹгҒ«гҒӘгӮҠгҒҫгҒҷгҖӮж®ӢгӮҠгҒ®гӮўгғ«гғҗгғ гҒҜгғҚгӮ№гғҲгҒ•гӮҢгҒҹгӮөгғ–гӮўгғ«гғҗгғ гҒ«гҒӘгӮҠгҒҫгҒҷгҖӮ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "мӮ¬м§„ лӘЁл“ңм—җм„ң нҸҙлҚ”м—җ 'в–¶пёҺ ' м ‘л‘җмӮ¬к°Җ л¶ҷмқҖ м•ЁлІ”мқҙ мһҲмңјл©ҙ н•ҙлӢ№ м•ЁлІ”мқҳ мӮ¬м§„мқҙ нҸҙлҚ” мһҗмІҙмқҳ мӮ¬м§„мқҙ лҗ©лӢҲлӢӨ. лӮҳлЁём§Җ м•ЁлІ”мқҖ н•ҳмң„ м•ЁлІ”мқҙ лҗ©лӢҲлӢӨ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "еңЁгҖҢз…§зүҮгҖҚжЁЎејҸдёӢпјҢеҰӮжһңж–Үд»¶еӨ№дёӯеҢ…еҗ«еҗҚз§°еүҚжңүгҖҢв–¶пёҺ гҖҚзҡ„зӣёеҶҢдё”еҗҚз§°дёҺж–Үд»¶еӨ№зӣёеҗҢпјҢиҜҘзӣёеҶҢзҡ„з…§зүҮе°ҶжҲҗдёәж–Үд»¶еӨ№жң¬иә«зҡ„еӣҫзүҮгҖӮе…¶дҪҷзӣёеҶҢе°ҶжҲҗдёәеөҢеҘ—еӯҗзӣёеҶҢгҖӮ"

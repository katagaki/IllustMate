    "Shared.DeleteConfirmation.Album": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete this pic?\nPics in the album will be moved to its containing album."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアルバムを削除してもよろしいですか？\nアルバム内の画像はそのアルバムの包含アルバムに戻されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앨범을 삭제하시겠습니까?\n앨범 내의 사진은 상위 앨범으로 이동됩니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除此相簿嗎？\n相簿中的圖片將被移至其上層相簿。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除此相册吗？\n相册中的图片将被移至其上级相册。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie dieses Album wirklich löschen?\nBilder im Album werden in das übergeordnete Album verschoben."
          }
        }
      }
    },
    "Shared.DeleteConfirmation.Album.%@": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete \"%@\"?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を削除してもよろしいですか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",

    "Libraries.Delete.Active.Message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Bibliothek ist gerade aktiv. Wechseln Sie zu einer anderen Bibliothek, bevor Sie sie löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This library is currently active. Switch to another library before deleting it."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このライブラリは現在アクティブです。削除する前に別のライブラリに切り替えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 라이브러리는 현재 활성화되어 있습니다. 삭제하기 전에 다른 라이브러리로 전환하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此资料库当前处于活动状态。请先切换到其他资料库再删除。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此資料庫目前處於使用中狀態。請先切換至其他資料庫再刪除。"
          }
        }
      }
    },
    "Libraries.Delete.Active.Title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktive Bibliothek kann nicht gelöscht werden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cannot Delete Active Library"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アクティブなライブラリは削除できません"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성 라이브러리는 삭제할 수 없습니다"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法删除活动资料库"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法刪除使用中的資料庫"
          }
        }
      }
    },
    "Libraries.Delete.Message %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Bilder und Alben in dieser Bibliothek dauerhaft gelöscht. Geben Sie zur Bestätigung den Code ein: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all pics and albums in this library. To confirm, enter the code: %@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このライブラリ内のすべての画像とアルバムが完全に削除されます。確認するには、コードを入力してください: %@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 라이브러리의 모든 사진과 앨범이 영구적으로 삭제됩니다. 확인하려면 코드를 입력하세요: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将永久删除此资料库中的所有图片和相册。请输入验证码以确认：%@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將永久刪除此資料庫中的所有圖片和相簿。請輸入驗證碼以確認：%@"
          }
        }
      }
    },

    "Libraries.Delete.Message %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Bilder und Alben in dieser Bibliothek dauerhaft gelöscht. Geben Sie zur Bestätigung den Code ein: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all pics and albums in this library. To confirm, enter the code: %@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このライブラリ内のすべての画像とアルバムが完全に削除されます。確認するには、コードを入力してください: %@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 라이브러리의 모든 사진과 앨범이 영구적으로 삭제됩니다. 확인하려면 코드를 입력하세요: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将永久删除此资料库中的所有图片和相册。请输入验证码以确认：%@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將永久刪除此資料庫中的所有圖片和相簿。請輸入驗證碼以確認：%@"
          }
        }
      }
    },

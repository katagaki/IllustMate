    "Backup.Confirm.Message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Fotos und Videos werden bei Bedarf heruntergeladen und in einer Sicherungsdatei gespeichert. Lass die App geöffnet, bis der Vorgang abgeschlossen ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every photo and video will be downloaded if needed and saved into one backup file. Keep the app open until it finishes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての写真とビデオが必要に応じてダウンロードされ、1つのバックアップファイルに保存されます。完了するまでAppを開いたままにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 사진과 동영상이 필요한 경우 다운로드되어 하나의 백업 파일로 저장됩니다. 완료될 때까지 앱을 열어 두세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有照片和视频将在需要时下载，并保存到一个备份文件中。请在完成前保持 App 打开。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有相片和影片將在需要時下載，並儲存至一個備份檔案中。請在完成前保持 App 開啟。"
          }
        }
      }
    },

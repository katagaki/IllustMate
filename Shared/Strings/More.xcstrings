    "Troubleshooting.ClearCache.Confirm.Message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden der Duplikatscan-Cache, der Farbsortierungs-Cache und der Albumcover-Cache dieser Bibliothek gelöscht. Sind Sie sicher?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will clear the duplicate scan cache, color sort cache, and album cover cache for this library. Are you sure?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このライブラリの重複スキャンキャッシュ、画像カラーキャッシュ、アルバムカバーキャッシュが消去されます。よろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 라이브러리의 중복 검사 캐시, 색상 정렬 캐시, 앨범 커버 캐시가 삭제됩니다. 계속하시겠습니까?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将清除此资料库的重复扫描缓存、颜色排序缓存和相册封面缓存。确定要继续吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將清除此資料庫的重複掃描快取、顏色排序快取和相簿封面快取。確定要繼續嗎？"
          }
        }
      }
    },

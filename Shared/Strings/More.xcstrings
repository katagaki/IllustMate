    "Backup.Error.Incomplete" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Originale konnten nicht heruntergeladen werden, daher wurde die Sicherung gestoppt. Überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some originals couldn’t be downloaded, so the backup was stopped. Check your connection and try again."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一部のオリジナルをダウンロードできなかったため、バックアップを中止しました。接続を確認して、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일부 원본을 다운로드할 수 없어 백업이 중단되었습니다. 연결을 확인한 후 다시 시도하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分原始文件无法下载，备份已停止。请检查网络连接后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分原始檔案無法下載，備份已停止。請檢查網路連線後再試一次。"
          }
        }
      }
    },

    "Experiments.NestedAlbums.Description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Fotos-Modus: Wenn ein Ordner ein Album mit „▶︎ “ vor dem Ordnernamen enthält, werden die Fotos dieses Albums zu den eigenen Bildern des Ordners. Die übrigen Alben werden zu verschachtelten Unteralben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Photos mode, if a folder contains an album with '▶︎ ' before the folder's name, that album's photos become the folder's own pics. Remaining albums become nested sub-albums."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真モードで、フォルダ内にフォルダ名の前に「▶︎ 」が付いたアルバムがある場合、そのアルバムの写真がフォルダ自体の写真になります。残りのアルバムはネストされたサブアルバムになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진 모드에서 폴더에 '▶︎ ' 접두사가 붙은 앨범이 있으면 해당 앨범의 사진이 폴더 자체의 사진이 됩니다. 나머지 앨범은 하위 앨범이 됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「照片」模式下，如果文件夹中包含名称前有「▶︎ 」的相册且名称与文件夹相同，该相册的照片将成为文件夹本身的图片。其余相册将成为嵌套子相册。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「照片」模式下，如果資料夾中包含名稱前有「▶︎ 」的相簿且名稱與資料夾相同，該相簿的照片將成為資料夾本身的圖片。其餘相簿將成為巢狀子相簿。"
          }
        }
      }
    },

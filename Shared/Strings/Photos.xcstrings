    "Sort.Explanation" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analysiert das Motiv jedes Bildes und schlägt ein Album zum Verschieben vor. Du bestätigst jede Verschiebung und kannst sie rückgängig machen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analyzes the subject of each pic and suggests an album to move it into. You confirm every move, and can undo afterwards."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各画像の被写体を解析し、移動先のアルバムを提案します。すべての移動を確認でき、後から取り消せます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 이미지의 피사체를 분석하여 옮길 앨범을 제안합니다. 모든 이동을 확인할 수 있으며 나중에 되돌릴 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分析每张图片的主体并建议要移动到的相册。每次移动都需确认，且可随后撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分析每張圖片的主體並建議要移動到的相簿。每次移動都需確認，且可隨後復原。"
          }
        }
      }
    },

    "Duplicates.NoDuplicatesFound.Message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In Ihrer Sammlung wurden keine visuell ähnlichen Bilder erkannt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No visually similar pics were detected in your collection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクション内に視覚的に類似する画像は検出されませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컬렉션에서 시각적으로 유사한 사진이 발견되지 않았습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在您的收藏中未检测到外观相似的图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在您的收藏中未偵測到外觀相似的圖片。"
          }
        }
      }
    },

    "Import.PhotosAccessDenied" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zugriff auf die Fotomediathek wurde verweigert. Bitte gewähren Sie den Zugriff in den Einstellungen, um Ihre Alben zu durchsuchen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos library access has been denied. Please grant access in Settings to browse your albums."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真ライブラリへのアクセスが拒否されています。アルバムを閲覧するには、設定でアクセスを許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진 보관함 접근이 거부되었습니다. 앨범을 탐색하려면 설정에서 접근 권한을 허용해 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片图库的访问权限已被拒绝。请在「设置」中授予访问权限以浏览您的相册。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片圖庫的存取權限已被拒絕。請在「設定」中授予存取權限以瀏覽您的相簿。"
          }
        }
      }
    },

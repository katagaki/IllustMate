    "Tips.NewAlbum.Message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle neue Alben, um deine Bilder zu ordnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create new albums to organize your pictures."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいアルバムを作成して画像を整理できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 앨범을 만들어 사진을 정리할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建新相册来整理你的图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "建立新相簿來整理你的圖片。"
          }
        }
      }

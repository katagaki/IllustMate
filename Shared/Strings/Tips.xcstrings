{
  "sourceLanguage": "en",
  "strings": {
    "Tips.Import.Message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst Bilder aus deiner Fotomediathek oder aus der Dateien-App importieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can import pictures from your Photos library or from the Files app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真ライブラリやファイルアプリから画像を読み込めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진 보관함이나 파일 앱에서 사진을 가져올 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以从照片图库或文件App导入图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以從照片圖庫或檔案App匯入圖片。"
          }
        }
      }
    },
    "Tips.Import.Title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilder importieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import Pictures"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像を読み込む"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진 가져오기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入图片"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入圖片"
          }
        }
      }
    },
    "Tips.Libraries.Message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle mehrere Mediatheken, um verschiedene Arten und Kategorien von Bildern zu organisieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create multiple libraries to further organize different types and categories of pictures."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "複数のライブラリを作成して、異なる種類やカテゴリの画像をさらに整理できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 라이브러리를 만들어 다양한 유형과 카테고리의 사진을 더욱 체계적으로 정리할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建多个资料库，进一步整理不同类型和分类的图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "建立多個資料庫，進一步整理不同類型和分類的圖片。"
          }
        }
      }
    },
    "Tips.Libraries.Title": {
      "extractionState": "manual",
      "localizations": {

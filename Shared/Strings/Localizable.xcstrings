    "Backup.Error.Incomplete" : {
      "comment" : "Title of a localized error message indicating that the backup was incomplete.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Originale konnten nicht heruntergeladen werden, daher wurde die Sicherung gestoppt. Überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some originals couldn’t be downloaded, so the backup was stopped. Check your connection and try again."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一部のオリジナルをダウンロードできなかったため、バックアップを中止しました。接続を確認して、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일부 원본을 다운로드할 수 없어 백업이 중단되었습니다. 연결을 확인한 후 다시 시도하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分原始文件无法下载，备份已停止。请检查网络连接后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分原始檔案無法下載，備份已停止。請檢查網路連線後再試一次。"
          }
        }
      }
    },
    "Backup.Error.InsufficientSpace" : {
      "comment" : "Error message when the backup cannot be completed because of insufficient free space on the destination.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es ist nicht genügend freier Speicher vorhanden, um diese Sicherung abzuschließen. Schaffe Speicherplatz und versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There isn’t enough free space to finish this backup. Free up space and try again."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このバックアップを完了するための空き容量が足りません。空き容量を増やしてから、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 백업을 완료할 공간이 부족합니다. 공간을 확보한 후 다시 시도하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可用空间不足，无法完成此备份。请释放空间后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可用空間不足，無法完成此備份。請釋放空間後再試一次。"
          }
        }
      }
    },

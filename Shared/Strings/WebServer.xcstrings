    "WebServer.KeepScreenOn.Description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verhindert, dass sich der Bildschirm ausschaltet, während der Webserver aktiv ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prevents the screen from turning off while the web server is active."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Webサーバーが動作中は画面がオフになるのを防ぎます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "웹 서버가 활성화된 동안 화면이 꺼지지 않도록 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Web 服务器运行时防止屏幕关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Web 伺服器運行時防止螢幕關閉。"
          }
        }
      }

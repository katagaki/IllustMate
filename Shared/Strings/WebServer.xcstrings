    "WebServer.Description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte einen Webserver, um Bilder von einem anderen Gerät im selben Netzwerk zu durchsuchen, herunterzuladen und hochzuladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start a web server to browse, download, and upload pics from another device on the same network."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Webサーバーを起動して、同じネットワーク上の他のデバイスから画像をブラウズ、ダウンロード、アップロードできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "같은 네트워크에 있는 다른 기기에서 사진을 탐색, 다운로드 및 업로드할 수 있는 웹 서버를 시작합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启动 Web 服务器，以便从同一网络上的其他设备浏览、下载和上传图片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟動 Web 伺服器，以便從同一網路上的其他裝置瀏覽、下載和上傳圖片。"
          }
        }
      }
    },
